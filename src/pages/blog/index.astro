---
import BasicLayout from '../../layouts/BasicLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts: CollectionEntry<'blog'>[] = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BasicLayout title="Blog">
	<main class="mx-auto max-w-3xl px-4 py-14">
		<!-- Titre -->
		<header class="mb-12 text-center">
			<h1 class="text-4xl font-extrabold tracking-tight text-gray-900 md:text-5xl">Blog</h1>
			<p class="mt-3 text-lg text-gray-500">Réflexions, retours d'expérience et veille créative.</p>
		</header>

		<!-- Liste des articles -->
		{posts.length > 0 ? (
			<ul class="divide-y divide-gray-100">
				{posts.map((post) => (
					<li>
						<a href={`/portfolio/blog/${post.id}/`} class="group flex flex-col gap-1 py-6 transition-colors hover:bg-emerald-50/40 -mx-4 px-4 rounded-xl">
							<div class="flex items-center gap-3 text-sm text-gray-400">
								<FormattedDate date={post.data.pubDate} />
								{post.data.tags && post.data.tags.length > 0 && (
									<span class="text-gray-200">·</span>
									<ul class="flex gap-1.5">
										{post.data.tags.slice(0, 3).map((tag: string) => (
											<li class="rounded-full bg-gray-100 px-2 py-0.5 text-[11px] font-medium text-gray-500">{tag}</li>
										))}
									</ul>
								)}
							</div>
							<h2 class="text-xl font-bold text-gray-900 group-hover:text-emerald-700 transition-colors leading-tight">
								{post.data.title}
							</h2>
							<p class="text-gray-500 text-sm leading-relaxed line-clamp-2 mt-1">
								{post.data.description}
							</p>
							<span class="mt-2 inline-flex items-center gap-1 text-xs font-semibold text-emerald-600 opacity-0 group-hover:opacity-100 transition-opacity">
								Lire l'article
								<svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
								</svg>
							</span>
						</a>
					</li>
				))}
			</ul>
		) : (
			<div class="text-center py-20">
				<div class="inline-flex items-center justify-center h-16 w-16 rounded-full bg-emerald-50 mb-4">
					<svg class="h-8 w-8 text-emerald-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5M6 7.5h3v3H6v-3z" />
					</svg>
				</div>
				<h2 class="text-xl font-semibold text-gray-900">Pas encore d'articles</h2>
				<p class="mt-2 text-gray-500">Les premiers articles arrivent bientôt. En attendant, découvrez <a href="/portfolio/projects/" class="text-emerald-600 hover:underline font-medium">mes projets</a>.</p>
			</div>
		)}
	</main>
</BasicLayout>