---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BasicLayout from '../../layouts/BasicLayout.astro';
import Prose from '../../components/Prose.astro';
import FormattedDate from '../../components/FormattedDate.astro';

export async function getStaticPaths() {
	const projects = await getCollection('projects');
	return projects.map((project) => ({
		params: { slug: project.id },
		props: project,
	}));
}

type Props = CollectionEntry<'projects'>;

const project = Astro.props;
const { Content } = await render(project);
---

<BasicLayout title={project.data.title}>
	<main class="mx-auto max-w-4xl px-4 py-14">
		<!-- Header du projet -->
		<header class="mb-10">
			<a href="/portfolio/projects/" class="inline-flex items-center gap-1.5 text-sm font-medium text-emerald-600 hover:text-emerald-700 transition-colors mb-6">
				<svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
				</svg>
				Retour aux projets
			</a>
			{project.data.heroImage && (
				<img
					src={project.data.heroImage}
					alt={`Image du projet ${project.data.title}`}
					class="w-full rounded-2xl shadow-md mb-8 object-cover max-h-[400px]"
				/>
			)}
			<h1 class="text-3xl font-extrabold tracking-tight text-gray-900 md:text-4xl">{project.data.title}</h1>
			<div class="mt-3 flex flex-wrap items-center gap-3 text-sm text-gray-500">
				<FormattedDate date={project.data.pubDate} />
				{project.data.tags && project.data.tags.length > 0 && (
					<span class="text-gray-300">·</span>
					<ul class="flex flex-wrap gap-1.5">
						{project.data.tags.map((tag: string) => (
							<li class="rounded-full bg-emerald-50 px-2.5 py-0.5 text-xs font-semibold text-emerald-700 ring-1 ring-emerald-200/70">{tag}</li>
						))}
					</ul>
				)}
			</div>
		</header>

		<!-- Contenu -->
		<Prose>
			<Content />
		</Prose>
	</main>
</BasicLayout>
